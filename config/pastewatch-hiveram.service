[Unit]
Description=pastewatch API proxy — scans nullbot WO payloads before reaching Hiveram
Documentation=https://github.com/ppiankov/nullbot-dist
Before=nullbot.service chainwatch-enforce.service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# Default upstream; overridden by NULLBOT_HIVERAM_UPSTREAM in hiveram.env
Environment=NULLBOT_HIVERAM_UPSTREAM=https://workledger.fly.dev
EnvironmentFile=-/root/.nullbot/hiveram.env
ExecStart=/bin/sh -c 'exec /usr/local/bin/pastewatch-cli proxy \
    --port 8444 \
    --upstream "$NULLBOT_HIVERAM_UPSTREAM" \
    --severity high \
    --audit-log /var/log/pastewatch/hiveram.jsonl \
    --alert'
Restart=on-failure
RestartSec=10

# Security hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/var/log/pastewatch
PrivateTmp=true
WorkingDirectory=/tmp

[Install]
WantedBy=multi-user.target
