# nullbot configuration
# Secrets are NEVER stored here — only env var names.

workledger:
  url: https://workledger.fly.dev/api/v1
  api_key_env: WORKLEDGER_API_KEY

llm:
  # LLM traffic is routed through pastewatch proxy (localhost:8443)
  # which scans and redacts secrets before forwarding to the upstream provider.
  # The proxy is configured in pastewatch-proxy.service.
  base_url: http://127.0.0.1:8443
  api_key_env: NULLBOT_LLM_API_KEY
  # Upstream provider (set in pastewatch-proxy.service via NULLBOT_LLM_UPSTREAM)
  # Default: https://api.groq.com
  # Options: https://api.openai.com, https://api.anthropic.com, https://openrouter.ai/api, etc.
